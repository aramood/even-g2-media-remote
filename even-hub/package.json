{
  "name": "even-hub",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "build": "tsc && vite build",
    "pack": "npm run build && evenhub pack app.json ./dist --output G2MediaRemote.ehpk",
    "pack:check": "npm run build && evenhub pack app.json ./dist --output G2MediaRemote.ehpk --check",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "sim": "node ./node_modules/@evenrealities/evenhub-simulator/bin/index.js http://127.0.0.1:5173/",
    "sim:glow": "node ./node_modules/@evenrealities/evenhub-simulator/bin/index.js --glow http://127.0.0.1:5173/",
    "sim:help": "node ./node_modules/@evenrealities/evenhub-simulator/bin/index.js --help",
    "typecheck": "tsc --noEmit",
    "qr": "evenhub qr --port 5173 --path /",
    "qr:url": "node ./scripts/print-qr.mjs",
    "tunnel": "cloudflared tunnel --url http://127.0.0.1:5173",
    "tunnel:qr": "node ./scripts/cloudflare-tunnel-qr.mjs",
    "evenhub:init": "evenhub init"
  },
  "devDependencies": {
    "@evenrealities/evenhub-cli": "^0.1.10",
    "@evenrealities/evenhub-simulator": "^0.6.2",
    "cloudflared": "^0.7.1",
    "qrcode-terminal": "^0.12.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.1"
  },
  "dependencies": {
    "@evenrealities/even_hub_sdk": "^0.0.9",
    "html-to-image": "^1.11.13"
  }
}
